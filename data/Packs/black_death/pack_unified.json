      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Changes to farming, prices and wages caused by the population fall."
        }
      }
    },
    {
      "id": "bd_vocab_046",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Land left unfarmed because there were fewer peasants to work it."
        }
      }
    },
    {
      "id": "bd_vocab_047",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Animals died because there were not enough peasants to care for them."
        }
      }
    },
    {
      "id": "bd_vocab_048",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Food became more expensive because supplies ran low."
        }
      }
    },
    {
      "id": "bd_vocab_049",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Surviving workers demanded more pay because labour was scarce."
        }
      }
    },
    {
      "id": "bd_vocab_050",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Unfree peasants who owed work to their lord and later resisted unpaid labour."
        }
      }
    },
    {
      "id": "bd_vocab_051",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Landowners who had to offer more food or money to attract workers after the plague."
        }
      }
    },
    {
      "id": "bd_vocab_052",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "A law that tried to keep wages at pre-Black Death levels but was often ignored."
        }
      }
    },
    {
      "id": "bd_vocab_053",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "A major rebellion partly linked to long-term tensions after the Black Death and the Poll Tax."
        }
      }
    },
    {
      "id": "bd_vocab_054",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "A tax introduced in 1381 that helped trigger the Peasants’ Revolt."
        }
      }
    },
    {
      "id": "bd_vocab_055",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Many people questioned the Church because priests and monks died despite prayer."
        }
      }
    },
    {
      "id": "bd_vocab_056",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "The textbook figure for clergy who died, reducing religious support."
        }
      }
    },
    {
      "id": "bd_vocab_057",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "The plague returned roughly every decade, reducing England’s population over the next century."
        }
      }
    },
    {
      "id": "bd_vocab_058",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "A Derbyshire village later famous for cutting itself off to stop plague spreading."
        }
      }
    },
    {
      "id": "bd_vocab_059",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "King of England during the outbreak; his daughter Joan died of the disease."
        }
      }
    },
    {
      "id": "bd_vocab_060",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "Daughter of King Edward III who died of the Black Death."
        }
      }
    },
    {
      "id": "bd_vocab_061",
      "type": "vocab",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death"
      ],
      "tags": [
        "KS3",
        "Year 7",
        "History",
        "The Black Death"
      ],
      "data": {
        "partOfSpeech": "keyword",
        "gender": null,
        "plural": null,
        "translations": {
          "en-GB": "The disease spread from ports across England within a year."
        }
      }
    },
    {
      "id": "bd_sentence_001",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Overview"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The Black Death was a severe outbreak of bubonic plague in England from 1348 to 1350."
        }
      }
    },
    {
      "id": "bd_sentence_002",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Causes"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The real cause was bubonic plague, spread by infected fleas that lived on rats."
        }
      }
    },
    {
      "id": "bd_sentence_003",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Dates",
        "Places"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The Black Death first reached England at Melcombe Regis in Dorset in June 1348."
        }
      }
    },
    {
      "id": "bd_sentence_004",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Causes"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Ports helped the plague spread because infected rats and fleas travelled on ships."
        }
      }
    },
    {
      "id": "bd_sentence_005",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Causes"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "One reason the plague spread quickly was that trade and shipping linked many towns and ports."
        }
      }
    },
    {
      "id": "bd_sentence_006",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Symptoms"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Early symptoms of the Black Death included sweating, coughing and fever."
        }
      }
    },
    {
      "id": "bd_sentence_007",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Symptoms"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Buboes were large painful lumps that appeared on victims’ bodies, often on the arms and legs."
        }
      }
    },
    {
      "id": "bd_sentence_008",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Symptoms"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Some lumps turned black because blood dried out inside the body."
        }
      }
    },
    {
      "id": "bd_sentence_009",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Symptoms"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Most people who caught the Black Death died within five days."
        }
      }
    },
    {
      "id": "bd_sentence_010",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Beliefs"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Many medieval people believed the plague was caused by bad air, also called miasma."
        }
      }
    },
    {
      "id": "bd_sentence_011",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Beliefs",
        "Religion"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Many people believed the Black Death was a punishment from God."
        }
      }
    },
    {
      "id": "bd_sentence_012",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Beliefs"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Some people prayed more because they believed God could save them from the disease."
        }
      }
    },
    {
      "id": "bd_sentence_013",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Treatments"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Doctors were unable to cure the Black Death because they did not understand bacteria, fleas or infection."
        }
      }
    },
    {
      "id": "bd_sentence_014",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Treatments"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Some people used dried flowers, herbs, toads, leeches, figs or butter as attempted treatments."
        }
      }
    },
    {
      "id": "bd_sentence_015",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Impact"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The Black Death killed about one-third of England’s population, around 1.5 million people."
        }
      }
    },
    {
      "id": "bd_sentence_016",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Social Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Many villages were abandoned because so many people died or moved away."
        }
      }
    },
    {
      "id": "bd_sentence_017",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Social Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Some Jews were wrongly blamed for causing the disease, so they were attacked or forced into separate areas."
        }
      }
    },
    {
      "id": "bd_sentence_018",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Economic Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "With fewer peasants, agricultural land was unused and livestock were left to die."
        }
      }
    },
    {
      "id": "bd_sentence_019",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Economic Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Food prices rose because fewer workers meant lower food supplies."
        }
      }
    },
    {
      "id": "bd_sentence_020",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Economic Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Workers could demand higher wages because there were fewer peasants and craftsmen available."
        }
      }
    },
    {
      "id": "bd_sentence_021",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Economic Effects"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Lords offered villeins more food and money to work their land."
        }
      }
    },
    {
      "id": "bd_sentence_022",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Government"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The Ordinance of Labourers was a 1349 law that tried to keep wages at pre-plague levels."
        }
      }
    },
    {
      "id": "bd_sentence_023",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Religion"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "Many people lost faith because priests, monks and those who prayed also died."
        }
      }
    },
    {
      "id": "bd_sentence_024",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Long Term"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The plague returned roughly every 10 years and England’s population declined over the following century."
        }
      }
    },
    {
      "id": "bd_sentence_025",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Long Term"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "The Black Death helped increase tensions over wages, labour duties and taxes before the Peasants’ Revolt of 1381."
        }
      }
    },
    {
      "id": "bd_sentence_026",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Significance"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "It changed population, wages, villages, religious attitudes and the relationship between peasants and lords."
        }
      }
    },
    {
      "id": "bd_sentence_027",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Misconceptions"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "A better explanation is that infected fleas living on rats spread the bubonic plague."
        }
      }
    },
    {
      "id": "bd_sentence_028",
      "type": "sentence",
      "level": "KS3 / Year 7",
      "topics": [
        "The Black Death",
        "Medicine"
      ],
      "tags": [],
      "data": {
        "translations": {
          "en-GB": "It showed that medieval medicine was based more on beliefs and observation than scientific understanding."
        }
      }
    }
  ]
}
