      "data": {
        "title": "How a Drumlin Forms",
        "instruction": "Put the steps in order to show how a drumlin develops.",
        "items": [
          "A glacier carries a large amount of till.",
          "The glacier meets an obstruction or a flatter valley floor.",
          "The ice loses energy and deposits material.",
          "The glacier continues moving over the deposited sediment.",
          "The sediment is streamlined into a smooth teardrop shape.",
          "A drumlin is left behind, often as part of a drumlin field."
        ],
        "shuffle": true
      }
    },
