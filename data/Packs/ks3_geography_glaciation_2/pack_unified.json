        "Glaciation 2"
      ],
      "tags": [
        "management",
        "process"
      ],
      "data": {
        "title": "Managing Tourist Pressure",
        "instruction": "Put the management chain in order.",
        "items": [
          "Large numbers of tourists visit a glacial landscape.",
          "Popular paths and roads become crowded and damaged.",
          "Managers identify the main pressure points, such as footpaths or lakes.",
          "Solutions are introduced, such as diversions, speed limits or public transport.",
          "Damage is reduced and the landscape gets time to recover.",
          "Tourism becomes more sustainable for local people and the environment."
        ],
        "shuffle": true
      }
